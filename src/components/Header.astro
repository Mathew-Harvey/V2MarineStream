---
import { serviceNav, tools } from "../data/navigation";

const path = Astro.url.pathname.replace(/\/$/, "") || "/";

function isPathMatch(href: string) {
  if (href.startsWith("http")) return false;
  const normalizedHref = href.replace(/\/$/, "").replace(/\.html$/, "");
  const normalizedPath = path.replace(/\.html$/, "");
  if (normalizedPath === normalizedHref) return true;
  if (normalizedHref.includes("ims-species-guide") && normalizedPath.includes("ims-species-guide")) return true;
  return normalizedPath.startsWith(normalizedHref + "/");
}

const servicesActive =
  path === "/services" || path.startsWith("/services/") || path.startsWith("/sales/");

const toolsActive = tools.some((tool) => isPathMatch(tool.href));
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="logo" href="/" aria-label="MarineStream home">
      <img
        src="/images/brand/marinestream_logo_white.png"
        alt="MarineStream™"
        width="180"
        height="40"
      />
    </a>

    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="site-nav"
      id="nav-toggle"
      aria-label="Open menu"
    >
      <span class="nav-toggle__bars" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
      <span class="nav-toggle__label">Menu</span>
    </button>

    <nav class="nav" id="site-nav" aria-label="Primary">
      <a href="/" aria-current={path === "/" ? "page" : undefined}>Home</a>
      <a href="/news" aria-current={isPathMatch("/news") || isPathMatch("/blog") ? "page" : undefined}>
        News
      </a>

      <div class:list={["nav-dropdown", { "is-active": servicesActive }]} data-nav-dropdown>
        <button
          class="nav-dropdown__toggle"
          type="button"
          aria-expanded="false"
          aria-controls="services-menu"
          aria-haspopup="true"
        >
          Services
        </button>
        <ul class="nav-dropdown__menu" id="services-menu" hidden>
          {
            serviceNav.map((item) => (
              <li>
                <a href={item.href} aria-current={isPathMatch(item.href) ? "page" : undefined}>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class:list={["nav-dropdown", { "is-active": toolsActive }]} data-nav-dropdown>
        <button
          class="nav-dropdown__toggle"
          type="button"
          aria-expanded="false"
          aria-controls="tools-menu"
          aria-haspopup="true"
        >
          Tools
        </button>
        <ul class="nav-dropdown__menu" id="tools-menu" hidden>
          {
            tools.map((tool) => (
              <li>
                <a href={tool.href} aria-current={isPathMatch(tool.href) ? "page" : undefined}>
                  {tool.menuLabel ?? tool.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <a href="/about" aria-current={isPathMatch("/about") ? "page" : undefined}>About</a>
      <a class="nav-cta" href="/contact">Contact us</a>
    </nav>
  </div>
  <div class="nav-backdrop" id="nav-backdrop" hidden></div>
</header>

<script>
  const MOBILE_MQ = "(max-width: 960px)";
  const toggle = document.getElementById("nav-toggle");
  const nav = document.getElementById("site-nav");
  const backdrop = document.getElementById("nav-backdrop");
  const dropdowns = document.querySelectorAll("[data-nav-dropdown]");

  function isMobileNav() {
    return window.matchMedia(MOBILE_MQ).matches;
  }

  function setNavOpen(open: boolean) {
    nav?.classList.toggle("is-open", open);
    document.body.classList.toggle("nav-open", open);
    toggle?.setAttribute("aria-expanded", open ? "true" : "false");
    toggle?.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    if (backdrop) {
      if (open) backdrop.removeAttribute("hidden");
      else backdrop.setAttribute("hidden", "");
    }
  }

  function closeNav() {
    setNavOpen(false);
  }

  function closeAllDropdowns() {
    dropdowns.forEach((dropdown) => {
      dropdown.classList.remove("is-open");
      dropdown.querySelector(".nav-dropdown__menu")?.setAttribute("hidden", "");
      dropdown.querySelector(".nav-dropdown__toggle")?.setAttribute("aria-expanded", "false");
    });
  }

  toggle?.addEventListener("click", () => {
    const open = !nav?.classList.contains("is-open");
    setNavOpen(!!open);
    if (!open) closeAllDropdowns();
  });

  backdrop?.addEventListener("click", () => {
    closeNav();
    closeAllDropdowns();
  });

  nav?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      if (isMobileNav()) {
        closeNav();
        closeAllDropdowns();
      }
    });
  });

  document.addEventListener("keydown", (event) => {
    if (event.key !== "Escape") return;
    closeNav();
    closeAllDropdowns();
  });

  window.addEventListener("resize", () => {
    if (!isMobileNav()) {
      closeNav();
    }
  });

  dropdowns.forEach((dropdown) => {
    const menu = dropdown.querySelector(".nav-dropdown__menu");
    const menuToggle = dropdown.querySelector(".nav-dropdown__toggle");
    let hoverCloseTimer: ReturnType<typeof setTimeout> | undefined;

    function openMenu() {
      dropdown.classList.add("is-open");
      menu?.removeAttribute("hidden");
      menuToggle?.setAttribute("aria-expanded", "true");
    }

    function closeMenu() {
      dropdown.classList.remove("is-open");
      menu?.setAttribute("hidden", "");
      menuToggle?.setAttribute("aria-expanded", "false");
    }

    menuToggle?.addEventListener("click", (event) => {
      event.stopPropagation();
      if (dropdown.classList.contains("is-open")) closeMenu();
      else {
        dropdowns.forEach((other) => {
          if (other !== dropdown) {
            other.classList.remove("is-open");
            other.querySelector(".nav-dropdown__menu")?.setAttribute("hidden", "");
            other.querySelector(".nav-dropdown__toggle")?.setAttribute("aria-expanded", "false");
          }
        });
        openMenu();
      }
    });

    dropdown.addEventListener("mouseenter", () => {
      if (isMobileNav()) return;
      if (hoverCloseTimer) clearTimeout(hoverCloseTimer);
      dropdowns.forEach((other) => {
        if (other !== dropdown) {
          other.classList.remove("is-open");
          other.querySelector(".nav-dropdown__menu")?.setAttribute("hidden", "");
          other.querySelector(".nav-dropdown__toggle")?.setAttribute("aria-expanded", "false");
        }
      });
      openMenu();
    });

    dropdown.addEventListener("mouseleave", () => {
      if (isMobileNav()) return;
      hoverCloseTimer = setTimeout(closeMenu, 120);
    });
  });

  document.addEventListener("click", (event) => {
    if (!event.target) return;
    dropdowns.forEach((dropdown) => {
      if (event.target instanceof Node && dropdown.contains(event.target)) return;
      dropdown.classList.remove("is-open");
      dropdown.querySelector(".nav-dropdown__menu")?.setAttribute("hidden", "");
      dropdown.querySelector(".nav-dropdown__toggle")?.setAttribute("aria-expanded", "false");
    });
  });
</script>
