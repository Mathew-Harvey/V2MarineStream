---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  lead?: string;
  eyebrow?: string;
  parent?: { href: string; label: string };
  image?: ImageMetadata;
  imageAlt?: string;
}

const { title, lead, eyebrow, parent, image, imageAlt = "" } = Astro.props;
---

<section class:list={["page-hero", { "page-hero--photo": image }]}>
  {
    image && (
      <div class="page-hero__bg" aria-hidden="true">
        <Picture
          src={image}
          alt={imageAlt}
          widths={[768, 1280, 1920]}
          sizes="100vw"
          formats={["avif", "webp"]}
          loading="eager"
          fetchpriority="high"
        />
      </div>
    )
  }
  <div class="container narrow">
    {
      parent && (
        <p class="breadcrumb">
          <a href="/">Home</a>
          {" / "}
          <a href={parent.href}>{parent.label}</a>
        </p>
      )
    }
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h1>{title}</h1>
    <hr class="accent-rule" />
    {lead && <p class="page-hero__lead">{lead}</p>}
    <slot />
  </div>
</section>
