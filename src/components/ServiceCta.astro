---
interface Props {
  eyebrow?: string;
  title: string;
  lead: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  eyebrow = "Next step",
  title,
  lead,
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel,
} = Astro.props;
---

<section class="section section--dark section--cta">
  <div class="container narrow">
    <span class="eyebrow">{eyebrow}</span>
    <h2>{title}</h2>
    <p>{lead}</p>
    <div class="btn-row">
      <a class="btn btn--primary" href={primaryHref}>{primaryLabel}</a>
      {
        secondaryHref && secondaryLabel && (
          <a class="btn btn--ghost" href={secondaryHref}>
            {secondaryLabel}
          </a>
        )
      }
    </div>
  </div>
</section>
