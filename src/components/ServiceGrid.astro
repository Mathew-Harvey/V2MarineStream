---
const services = [
  {
    href: "/services/inspection",
    title: "Inspection",
    body: "ROV and diver surveys with live access and fouling ratings on the spot.",
  },
  {
    href: "/services/cleaning",
    title: "Cleaning with capture",
    body: "In-water cleaning with 10μ filtration and UV — IMO and Australian standards.",
  },
  {
    href: "/services/platform",
    title: "Platform",
    body: "Field capture, parallel approvals, automated reports, blockchain audit.",
  },
  {
    href: "/services/expertise",
    title: "IMS expertise",
    body: "Marine scientists for identification, risk, and treatment guidance.",
  },
];
---

<ol class="offer-list">
  {
    services.map((s) => (
      <li>
        <a href={s.href}>
          <strong>{s.title}</strong>
          <span>{s.body}</span>
        </a>
      </li>
    ))
  }
</ol>
