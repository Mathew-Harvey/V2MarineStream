---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const props = Astro.props;
---

<BaseLayout {...props}>
  <slot name="head" slot="head" />
  <Header slot="header" />
  <slot />
  <Footer slot="footer" />
</BaseLayout>
