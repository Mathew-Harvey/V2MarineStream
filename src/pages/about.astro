---
import SiteLayout from "../layouts/SiteLayout.astro";
import PageHero from "../components/PageHero.astro";
import ServiceCta from "../components/ServiceCta.astro";
import { Image } from "astro:assets";
import bannerImage from "../assets/photos/crawler-supervision.jpg";
import interviewImage from "../assets/photos/media-interview.jpg";
import teamImage from "../assets/photos/team-portrait-hoses.jpg";
import deckImage from "../assets/photos/deck-golden-hour.jpg";
import operatorImage from "../assets/photos/dockside-operator.jpg";
import commissioningImage from "../assets/photos/commissioning-team.jpg";
import submarineImage from "../assets/photos/submarine-alongside.jpg";

import absLogo from "../assets/logos/abs.jpg";
import bvLogo from "../assets/logos/bv.jpg";
import dnvLogo from "../assets/logos/dnv.jpg";
import lrLogo from "../assets/logos/lr.jpg";
import nkLogo from "../assets/logos/nk.jpg";

const classLogos = [
  { src: absLogo, alt: "American Bureau of Shipping" },
  { src: bvLogo, alt: "Bureau Veritas" },
  { src: dnvLogo, alt: "DNV" },
  { src: lrLogo, alt: "Lloyd's Register" },
  { src: nkLogo, alt: "ClassNK" },
];

const highlightStats = [
  { value: "1981", label: "Franmarine founded — decades of underwater sustainment" },
  { value: "120+", label: "Vessels inspected and cleaned to standard" },
  { value: "1st", label: "Commercial in-water cleaning port agreement in Australia" },
  { value: "ISO", label: "9001 · 14001 · 45001 certified, DNV" },
];

const stackServices = [
  {
    href: "/services/hardware",
    num: "01 · HARDWARE",
    title: "Eyes and tools on the hull",
    body: "Inspection ROVs, the cleaning crawler, and full-capture filtration — three tiers of intervention.",
    cta: "Hardware →",
  },
  {
    href: "/services/software",
    num: "02 · SOFTWARE",
    title: "The record everyone shares",
    body: "Capture once, review in parallel, and the compliance report writes itself from the job.",
    cta: "Software →",
  },
  {
    href: "/services/training",
    num: "03 · TRAINING",
    title: "Crews who run it unsupervised",
    body: "A five-module program from our own operating manual, assessed against a written standard.",
    cta: "Training →",
  },
  {
    href: "/services/professional-services",
    num: "04 · PRO SERVICES",
    title: "The program around it",
    body: "A DPIRD-accredited inspector and advisory that make the whole stack pass an audit.",
    cta: "Professional services →",
    accent: true,
  },
];

const commitments = [
  {
    title: "IMO aligned",
    body: "Inspection, cleaning with capture and records mapped to the biofouling guidelines.",
    tone: "deep",
  },
  {
    title: "Field proven",
    body: "Equipment and workflows proven on Navy and commercial vessel operations first.",
    tone: "deep",
  },
  {
    title: "Audit ready",
    body: "One digital trail — ratings, evidence, approvals and reports in a single place.",
    tone: "deep",
  },
  {
    title: "Partner first",
    body: "We uplift contractors and ROV teams rather than compete for every diver day.",
    tone: "orange",
  },
];

const defenceStats = [
  { value: "85+", label: "RAN vessels serviced" },
  { value: "DISP", label: "Defence-certified supply chain" },
  { value: "2", label: "Independently audited operations" },
];
---

<SiteLayout
  title="About | MarineStream™"
  description="MarineStream is a division of Franmarine, enabling partners to deliver IMO-aligned biofouling work."
>
  <div class="about-hero-wrap">
    <PageHero
      eyebrow="A division of Franmarine"
      title="About MarineStream"
      lead="Built by the people who run underwater sustainment — so partners can deliver compliant biofouling work on the same systems we trust ourselves."
      image={bannerImage}
      imageAlt="Operator supervising a hull crawler working at a ship's waterline"
    />

    <section class="section about-pull">
      <div class="container">
        <div class="about-stats reveal">
          {
            highlightStats.map((stat) => (
              <div class="about-stats__card">
                <div class="about-stats__value">{stat.value}</div>
                <div class="about-stats__label">{stat.label}</div>
              </div>
            ))
          }
        </div>

        <div class="grid-2 about-story">
          <div class="reveal">
            <span class="eyebrow">The story</span>
            <h2>Operational systems, not shelfware</h2>
            <hr class="accent-rule" />
            <p>
              Franmarine has delivered underwater sustainment and biofouling management for decades,
              from Henderson, Western Australia. MarineStream is the platform and capability stack
              that makes that work transparent, standardised and auditable — now available to diving
              contractors, hull cleaners and ROV operators.
            </p>
            <p>
              The people behind it run the operations themselves: commercial diving, ROV inspection,
              in-water cleaning with capture, and marine science. That experience shapes everything —
              from the hardware we supply to the way the platform structures a job record.
            </p>
            <p>
              <a href="https://www.franmarine.com.au/" rel="noopener noreferrer">Visit Franmarine →</a>
            </p>
          </div>
          <figure class="about-story__figure reveal">
            <Image
              src={interviewImage}
              alt="MarineStream spokesperson beside an inspection ROV"
              widths={[480, 900]}
              sizes="(min-width: 800px) 32rem, 100vw"
              loading="lazy"
            />
            <figcaption>Clean. Survey. Maintain. Repair. Sustain — the words behind the work.</figcaption>
          </figure>
        </div>
      </div>
    </section>
  </div>

  <section class="section section--dark">
    <div class="container">
      <div class="reveal">
        <span class="eyebrow">One capability stack</span>
        <h2>Four services, one job record</h2>
        <hr class="accent-rule" />
        <p class="about-stack__lead">
          Everything we offer is one loop, not four products. Hardware puts eyes and tools on the
          hull; software turns what they see into a compliant record; training certifies the crews
          who run it; and professional services shape the program it all sits inside. Each stands
          alone — together they close the loop from first inspection to signed-off report.
        </p>
      </div>
      <div class="about-stack">
        {
          stackServices.map((service) => (
            <a
              class:list={["about-stack__card", "reveal", { "about-stack__card--accent": service.accent }]}
              href={service.href}
            >
              <span class="about-stack__num">{service.num}</span>
              <h3>{service.title}</h3>
              <p>{service.body}</p>
              <span class="about-stack__cta">{service.cta}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="eyebrow">How we work</span>
      <h2>Four commitments</h2>
      <hr class="accent-rule" />
      <div class="about-commitments">
        {
          commitments.map((item) => (
            <div class:list={["about-commitments__card", "reveal", `about-commitments__card--${item.tone}`]}>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container tech-band__grid">
      <div class="reveal">
        <span class="eyebrow">Proven where it counts</span>
        <h2>Defence-grade discipline, commercial pace</h2>
        <hr class="accent-rule" />
        <p>
          MarineStream systems and crews work on Royal Australian Navy vessels and across commercial
          fleets — more than 120 vessels inspected and cleaned to standard. The same record-keeping
          that satisfies defence customers is what makes commercial audits fast.
        </p>
        <div class="about-defence-stats">
          {
            defenceStats.map((stat) => (
              <div>
                <div class="about-defence-stats__value">{stat.value}</div>
                <div class="about-defence-stats__label">{stat.label}</div>
              </div>
            ))
          }
        </div>
      </div>
      <div class="tech-band__media reveal">
        <Image
          src={submarineImage}
          alt="Submarine alongside a wharf in clear turquoise water"
          widths={[480, 900]}
          sizes="(max-width: 860px) 100vw, 50vw"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="eyebrow">The team</span>
      <h2>People who own the outcome</h2>
      <hr class="accent-rule" />
      <div class="about-mosaic reveal">
        <figure class="about-mosaic__hero">
          <Image
            src={teamImage}
            alt="Team member in front of racked dive umbilicals"
            widths={[480, 900]}
            sizes="(max-width: 860px) 100vw, 42vw"
            loading="lazy"
            style="object-position: 50% 22%"
          />
          <figcaption>Dive operations, run in-house.</figcaption>
        </figure>
        <figure class="about-mosaic__wide">
          <Image
            src={operatorImage}
            alt="Operator using a handheld control unit dockside"
            widths={[480, 900]}
            sizes="(max-width: 860px) 100vw, 58vw"
            loading="lazy"
          />
          <figcaption>ROV pilots who also train partner crews.</figcaption>
        </figure>
        <figure class="about-mosaic__mid">
          <Image
            src={deckImage}
            alt="Crew member on a workboat deck at golden hour"
            widths={[400, 720]}
            sizes="(max-width: 860px) 100vw, 33vw"
            loading="lazy"
          />
          <figcaption>On the water at whatever hour the job needs.</figcaption>
        </figure>
        <figure class="about-mosaic__narrow">
          <Image
            src={commissioningImage}
            alt="Project team in front of a containerised treatment unit on commissioning day"
            widths={[360, 640]}
            sizes="(max-width: 860px) 100vw, 25vw"
            loading="lazy"
          />
          <figcaption>Commissioning day — team and client together.</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="trust-bar" aria-label="Certifications and standards">
    <div class="container">
      <p class="trust-bar__label">Working to classification society and ISO standards</p>
      <div class="trust-bar__logos">
        {classLogos.map((logo) => <Image src={logo.src} alt={logo.alt} loading="lazy" />)}
      </div>
      <p class="trust-bar__certs">Certified ISO 9001, ISO 14001 and ISO 45001</p>
    </div>
  </section>

  <ServiceCta
    title="Work with us"
    lead="Whether you need the work delivered or your own capability uplifted, it starts with a conversation."
    primaryHref="/contact"
    primaryLabel="Get in touch"
    secondaryHref="/services"
    secondaryLabel="Our services"
  />
</SiteLayout>
