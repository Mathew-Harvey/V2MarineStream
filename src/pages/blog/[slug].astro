---
import { getCollection } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import PageHero from "../../components/PageHero.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const morePosts = (await getCollection("blog", ({ data }) => !data.draft))
  .filter((p) => p.slug !== post.slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

const postThumbs: Record<string, string> = {
  "beyond-the-surface": "/images/blog/beyond-the-surface/IMG_5414.jpg",
  "clean-hulls-clear-waters": "/images/blog/clean-hulls-clear-waters/digitalPlatform.jpg",
  "from-rov-to-remote": "/images/blog/from-rov-to-remote/1.jpg",
  "the-hull-truth": "/images/blog/the-hull-truth/aquamars.png",
  "preventative-advantage": "/images/blog/preventative-advantage/Image 2 (1).png",
  "revolutionising-underwater-inspections":
    "/images/blog/revolutionising-underwater-inspections/shipDryDock.png",
};

const ogImage = post.data.image ?? postThumbs[post.slug] ?? "/images/og-default.jpg";

function formatDate(d: Date) {
  return d.toLocaleDateString("en-AU", { year: "numeric", month: "long", day: "numeric" });
}
---

<SiteLayout
  title={`${post.data.title} | MarineStream`}
  description={post.data.description}
  ogImage={ogImage}
  ogType="article"
>
  <PageHero
    eyebrow="News"
    title={post.data.title}
    lead={`${formatDate(post.data.pubDate)} · ${post.data.author}`}
    parent={{ href: "/news", label: "News" }}
  />

  <section class="section">
    <div class="container prose">
      <Content />
      <p style="margin-top: var(--space-lg);">
        <a href="/news">← News</a>
      </p>
    </div>
  </section>

  {
    morePosts.length > 0 && (
      <section class="section section--soft">
        <div class="container narrow">
          <span class="eyebrow">Keep reading</span>
          <h2>More from the news</h2>
          <hr class="accent-rule" />
          {morePosts.map((p) => (
            <a class="blog-card" href={`/blog/${p.slug}`}>
              <div class="blog-card__meta">
                {formatDate(p.data.pubDate)} · {p.data.author}
              </div>
              <h3>{p.data.title}</h3>
              <p>{p.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )
  }
</SiteLayout>
