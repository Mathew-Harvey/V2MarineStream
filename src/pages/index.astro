---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="MarineStream™ — IMO-Compliant Biofouling Inspections & Cleans"
  description="Enable your teams to deliver IMO-compliant biofouling inspections and cleans — powered by MarineStream."
  ogImage="/images/brand/socialmedialogo.png"
>
  <section class="hero">
    <div class="hero__media" aria-hidden="true"></div>
    <div class="container hero__inner">
      <span class="eyebrow">Biofouling &amp; underwater asset management</span>
      <h1>IMO-compliant biofouling inspections and cleans</h1>
      <hr class="accent-rule" />
      <p class="hero__lead">
        The system that uplifts diving contractors, hull cleaners, and ROV operators — platform,
        cleaning with capture, and marine science expertise.
      </p>
      <div class="btn-row">
        <a class="btn btn--primary" href="/contact">Talk to us</a>
        <a class="btn btn--ghost" href="/services">See what we do</a>
      </div>
    </div>
  </section>

  <svg class="wave-divider" viewBox="0 0 1440 44" preserveAspectRatio="none" aria-hidden="true">
    <path fill="#ffffff" d="M0,22 C240,44 480,0 720,14 C960,28 1200,44 1440,18 L1440,44 L0,44 Z"></path>
  </svg>

  <section class="section section--topo">
    <div class="container narrow">
      <span class="eyebrow">What we do</span>
      <h2>Four services. One system.</h2>
      <ol class="offer-list">
        <li>
          <a href="/services/inspection">
            <strong>Inspection</strong>
            <span>ROV and diver surveys with live access and fouling ratings on the spot.</span>
          </a>
        </li>
        <li>
          <a href="/services/cleaning">
            <strong>Cleaning with capture</strong>
            <span>In-water cleaning with 10μ filtration and UV — IMO and Australian standards.</span>
          </a>
        </li>
        <li>
          <a href="/services/platform">
            <strong>Platform</strong>
            <span>Field capture, parallel approvals, automated reports, blockchain audit.</span>
          </a>
        </li>
        <li>
          <a href="/services/expertise">
            <strong>IMS expertise</strong>
            <span>Marine scientists for identification, risk, and treatment guidance.</span>
          </a>
        </li>
      </ol>

      <div class="media-strip" aria-label="MarineStream in the field">
        <figure>
          <img
            src="/images/photos/rov-inspection.png"
            alt="ROV inspection operations"
            loading="lazy"
            width="800"
            height="500"
          />
          <figcaption>Inspection</figcaption>
        </figure>
        <figure>
          <img
            src="/images/photos/filtration-unit.jpg"
            alt="MarineStream filtration unit for cleaning with capture"
            loading="lazy"
            width="600"
            height="400"
          />
          <figcaption>Cleaning with capture</figcaption>
        </figure>
        <figure>
          <img
            src="/images/photos/platform-mock.png"
            alt="MarineStream digital platform"
            loading="lazy"
            width="600"
            height="400"
          />
          <figcaption>Platform</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container narrow">
      <span class="eyebrow">How it works</span>
      <h2>Measure. Clean. Record.</h2>
      <div class="flow">
        <div>
          <strong>Measure</strong>
          <p>Survey and rate fouling. Stakeholders see the same live evidence.</p>
        </div>
        <div>
          <strong>Clean</strong>
          <p>In-water cleaning with capture through our filtration units — no open discharge.</p>
        </div>
        <div>
          <strong>Record</strong>
          <p>One digital record. Automated reports. Audit-ready by default.</p>
        </div>
      </div>
      <p class="proof-line">
        Proven on Royal Australian Navy operations · 80% less reporting time · 120+ vessels
      </p>
    </div>
  </section>

  <section class="section section--dark section--cta">
    <div class="container narrow">
      <span class="eyebrow">Next step</span>
      <h2>Ready to uplift your capability?</h2>
      <p>Platform access, cleaning with capture systems, and IMS expertise for your teams.</p>
      <a class="btn btn--primary" href="/contact">Contact MarineStream</a>
    </div>
  </section>
</SiteLayout>
