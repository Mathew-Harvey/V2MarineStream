---
import { getCollection } from "astro:content";
import SiteLayout from "../layouts/SiteLayout.astro";
import { serviceNav } from "../data/navigation";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<SiteLayout
  title="MarineStream™ — IMO-Compliant Biofouling Inspections & Cleans"
  description="Enable your teams to deliver IMO-compliant biofouling inspections and cleans — powered by MarineStream."
  ogImage="/images/brand/socialmedialogo.png"
>
  <!-- 1. Hero -->
  <section class="hero">
    <div class="hero__media" aria-hidden="true"></div>
    <div class="container hero__inner">
      <span class="eyebrow">Biofouling &amp; underwater asset management</span>
      <h1>IMO-compliant biofouling inspections and cleans</h1>
      <hr class="accent-rule" />
      <p class="hero__lead">
        Enabling diving contractors, hull cleaners, and ROV operators to deliver compliant work —
        with platform, capture systems, and marine science expertise.
      </p>
      <div class="btn-row">
        <a class="btn btn--primary" href="/portfolio">Portfolio</a>
      </div>
    </div>
  </section>

  <svg class="wave-divider" viewBox="0 0 1440 44" preserveAspectRatio="none" aria-hidden="true">
    <path fill="#ffffff" d="M0,22 C240,44 480,0 720,14 C960,28 1200,44 1440,18 L1440,44 L0,44 Z"></path>
  </svg>

  <!-- 2. Trust intro -->
  <section class="section">
    <div class="container narrow home-centered">
      <h2>Built for partners who deliver the work</h2>
      <hr class="accent-rule accent-rule--center" />
      <p>
        MarineStream™ is a division of Franmarine. We supply the hardware, software, training, and
        IMS expertise that uplift diving contractors, hull cleaners, and ROV operators — so they can
        run IMO-aligned inspections and cleans with one auditable record.
      </p>
    </div>
  </section>

  <!-- 3. Proof / partners -->
  <section class="section section--soft">
    <div class="container narrow home-centered">
      <span class="eyebrow">Proven in the field</span>
      <p class="proof-line">
        Royal Australian Navy operations · 80% less reporting time · 120+ vessels · A division of
        Franmarine
      </p>
    </div>
  </section>

  <!-- 4. About snippet -->
  <section class="section">
    <div class="container narrow">
      <span class="eyebrow">About us</span>
      <h2>Operational systems, not shelfware</h2>
      <hr class="accent-rule" />
      <p>
        Franmarine has delivered underwater sustainment for decades. MarineStream packages that
        capability — filtration units, platform workflows, and marine scientists — for partners who
        need the same standard without building it alone.
      </p>
      <div class="btn-row">
        <a class="btn btn--navy" href="/about">More about us</a>
      </div>
    </div>
  </section>

  <!-- 5. Trust pillars -->
  <section class="section section--soft">
    <div class="container">
      <div class="pillar-grid">
        <div>
          <h3>IMO aligned</h3>
          <p>Inspection, cleaning with capture, and records mapped to biofouling guidelines.</p>
        </div>
        <div>
          <h3>Field proven</h3>
          <p>Equipment and workflows proven on Navy and commercial vessel operations.</p>
        </div>
        <div>
          <h3>Audit ready</h3>
          <p>One digital trail — rates, evidence, approvals, and reports in one place.</p>
        </div>
        <div>
          <h3>Partner first</h3>
          <p>We uplift contractors and ROV teams rather than competing for every diver day.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. Dual capability CTAs -->
  <section class="section section--dark">
    <div class="container dual-cta">
      <div>
        <span class="eyebrow">Field systems</span>
        <h2>Inspection &amp; cleaning</h2>
        <p>Hardware and capture systems partners use to survey and clean to standard.</p>
        <a class="btn btn--primary" href="/services/inspection">Discover services</a>
      </div>
      <div>
        <span class="eyebrow">Professional services</span>
        <h2>Platform &amp; expertise</h2>
        <p>Software, training, consulting, and IMS science when identification matters.</p>
        <a class="btn btn--ghost" href="/services/expertise">Discover services</a>
      </div>
    </div>
  </section>

  <!-- 7. What we do -->
  <section class="section section--topo">
    <div class="container">
      <div class="home-centered">
        <span class="eyebrow">What we do</span>
        <h2>Services</h2>
        <hr class="accent-rule accent-rule--center" />
      </div>
      <div class="service-tile-grid">
        {
          serviceNav.map((s) => (
            <a class="service-tile" href={s.href}>
              <strong>{s.label}</strong>
              <span>{s.description}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 8. Expertise -->
  <section class="section">
    <div class="container narrow">
      <span class="eyebrow">Our expertise</span>
      <h2>Measure. Clean. Record.</h2>
      <hr class="accent-rule" />
      <div class="flow">
        <div>
          <strong>Measure</strong>
          <p>Survey and rate fouling. Stakeholders see the same live evidence.</p>
        </div>
        <div>
          <strong>Clean</strong>
          <p>In-water cleaning with capture — no open discharge.</p>
        </div>
        <div>
          <strong>Record</strong>
          <p>One digital record. Automated reports. Audit-ready by default.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 9. Team / about -->
  <section class="section section--soft">
    <div class="container narrow home-centered">
      <span class="eyebrow">The team</span>
      <h2>A division of Franmarine</h2>
      <hr class="accent-rule accent-rule--center" />
      <p>
        Built by people who run underwater sustainment, ROV inspection, and biofouling management —
        not a software team guessing what the field needs.
      </p>
      <div class="btn-row" style="justify-content: center;">
        <a class="btn btn--navy" href="/about">More about us</a>
      </div>
    </div>
  </section>

  <!-- 10. Latest portfolio -->
  <section class="section">
    <div class="container narrow">
      <span class="eyebrow">Latest projects</span>
      <h2>Portfolio</h2>
      <hr class="accent-rule" />
      {
        posts.map((post) => (
          <a class="blog-card" href={`/blog/${post.slug}`}>
            <div class="blog-card__meta">{post.data.author}</div>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
          </a>
        ))
      }
      <div class="btn-row">
        <a class="btn btn--navy" href="/portfolio">View all</a>
      </div>
    </div>
  </section>

  <!-- 11. Final CTA -->
  <section class="section section--dark section--cta">
    <div class="container narrow">
      <span class="eyebrow">Next step</span>
      <h2>Ready to uplift your capability?</h2>
      <p>Hardware, platform access, training, and IMS expertise for your teams.</p>
      <a class="btn btn--primary" href="/contact">Contact us</a>
    </div>
  </section>
</SiteLayout>
