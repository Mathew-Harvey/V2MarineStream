---
import { getCollection } from "astro:content";
import SiteLayout from "../layouts/SiteLayout.astro";
import PageHero from "../components/PageHero.astro";
import bannerImage from "../assets/photos/dusk-aerial.jpg";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function formatDate(d: Date) {
  return d.toLocaleDateString("en-AU", { year: "numeric", month: "long", day: "numeric" });
}
---

<SiteLayout
  title="Portfolio | MarineStream™"
  description="Case studies and insight on biofouling inspection, cleaning with capture, and maritime compliance."
>
  <PageHero
    eyebrow="Work & insight"
    title="Portfolio"
    lead="Projects, pilots, and practical writing from MarineStream operations."
    image={bannerImage}
    imageAlt="Aerial view of a port facility at dusk"
  />

  <section class="section">
    <div class="container narrow">
      {
        posts.map((post) => (
          <a class="blog-card" href={`/blog/${post.slug}`}>
            <div class="blog-card__meta">
              {formatDate(post.data.pubDate)} · {post.data.author}
            </div>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
          </a>
        ))
      }
    </div>
  </section>
</SiteLayout>
