---
import SiteLayout from "../../layouts/SiteLayout.astro";
import PageHero from "../../components/PageHero.astro";
import SalesGrid from "../../components/SalesGrid.astro";
import { imsExpertise } from "../../data/sales";
---

<SiteLayout
  title="Sales | MarineStream™"
  description="Hardware, software, training, and professional services for IMO-compliant biofouling operations."
>
  <PageHero
    eyebrow="What we sell"
    title="Sales"
    lead="Equipment, platform access, training, and expert support — built from our own field operations."
  />

  <section class="section section--topo">
    <div class="container narrow">
      <span class="eyebrow">Catalogue</span>
      <h2>Hardware, software, and training</h2>
      <hr class="accent-rule" />
      <SalesGrid />
    </div>
  </section>

  <section class="section section--soft">
    <div class="container narrow">
      <span class="eyebrow">Professional services</span>
      <h2>{imsExpertise.label}</h2>
      <hr class="accent-rule" />
      <p>{imsExpertise.description}</p>
      <ul>
        {imsExpertise.features.map((feature) => <li>{feature}</li>)}
      </ul>
      <p>
        IMS expertise sits under our professional services offering — unique science capability that
        closes the loop when surveys find something unexpected.
      </p>
      <div class="btn-row">
        <a class="btn btn--navy" href={imsExpertise.href}>IMS expertise</a>
        <a class="btn btn--primary" href="/contact">Request a quote</a>
      </div>
    </div>
  </section>
</SiteLayout>
