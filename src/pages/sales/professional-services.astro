---
import SiteLayout from "../../layouts/SiteLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { imsExpertise } from "../../data/sales";
---

<SiteLayout
  title="Professional Services | Sales | MarineStream™"
  description="Maritime consulting, program design, and operational support for biofouling compliance."
>
  <PageHero
    eyebrow="Sales"
    title="Professional services"
    lead="Consulting and advisory support for partners building or scaling IMO-compliant capability."
    parent={{ href: "/sales", label: "Sales" }}
  />

  <section class="section">
    <div class="container narrow">
      <ul>
        <li>Compliance and biofouling program design</li>
        <li>Operational consulting for inspection and cleaning workflows</li>
        <li>Reporting setup aligned to biosecurity and defence requirements</li>
        <li>Ongoing advisory and review support</li>
      </ul>
      <p>
        Professional services cover the advisory layer — how your teams work, what they record, and
        how stakeholders sign off.
      </p>
      <div class="btn-row">
        <a class="btn btn--navy" href="/contact">Talk to our team</a>
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container narrow">
      <span class="eyebrow">Professional services</span>
      <h2>{imsExpertise.label}</h2>
      <hr class="accent-rule" />
      <p>{imsExpertise.description}</p>
      <ul>
        {imsExpertise.features.map((feature) => <li>{feature}</li>)}
      </ul>
      <p>
        IMS expertise is a distinct capability within professional services — marine science when
        identification and risk judgement matter.
      </p>
      <div class="btn-row">
        <a class="btn btn--primary" href={imsExpertise.href}>IMS expertise</a>
      </div>
    </div>
  </section>
</SiteLayout>
