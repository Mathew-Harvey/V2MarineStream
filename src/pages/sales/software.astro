---
import SiteLayout from "../../layouts/SiteLayout.astro";
import PageHero from "../../components/PageHero.astro";
---

<SiteLayout
  title="Software | Sales | MarineStream™"
  description="MarineStream platform subscriptions — field capture, workflows, and compliance reporting."
>
  <PageHero
    eyebrow="Sales"
    title="Software"
    lead="Platform access for partners who need audit-ready records without rebuilding reporting every job."
    parent={{ href: "/sales", label: "Sales" }}
  />

  <section class="section">
    <div class="container narrow">
      <img
        class="service-photo"
        src="/images/photos/platform-mock.png"
        alt="MarineStream platform"
        loading="lazy"
        width="900"
        height="560"
      />
      <ul>
        <li>Platform subscriptions for field teams and fleet operators</li>
        <li>Mobile capture — photo, video, ROV/CCTV ingest, and fouling ratings</li>
        <li>Parallel approval workflows and automated compliance reports</li>
        <li>Onboarding, integration, and ongoing support</li>
      </ul>
      <p>
        Software is sold as part of a working system — inspection, cleaning, and reporting connected
        in one record.
      </p>
      <div class="btn-row">
        <a class="btn btn--navy" href="/contact">Request platform access</a>
        <a class="btn btn--primary" href="/services/platform">Platform overview</a>
      </div>
    </div>
  </section>
</SiteLayout>
