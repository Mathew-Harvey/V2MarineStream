---
import SiteLayout from "../../layouts/SiteLayout.astro";
import PageHero from "../../components/PageHero.astro";
---

<SiteLayout
  title="Cleaning with Capture | MarineStream™"
  description="In-water hull and niche-area cleaning with capture — 10μ filtration and UV treatment aligned to IMO and Australian standards."
>
  <PageHero
    eyebrow="Services"
    title="Cleaning with capture"
    lead="In-water cleaning with capture — aligned to IMO and Australian biosecurity requirements."
    parent={{ href: "/services", label: "Services" }}
  />

  <section class="section">
    <div class="container narrow">
      <img
        class="service-photo"
        src="/images/photos/filtration-unit.jpg"
        alt="MarineStream 10μ filtration and water treatment unit"
        loading="lazy"
        width="900"
        height="560"
      />
      <ul>
        <li>Capture and filtration to 10μ, with UV treatment</li>
        <li>Single 20′ container — deployable from wharf or support vessel</li>
        <li>Works with divers, hand tools, and ROV systems</li>
        <li>Niche areas: sea chests, shafts, rudders, thrusters</li>
      </ul>
      <p>
        Capture matters where open cleaning is restricted. Dislodged biofouling is filtered and
        treated so partners can operate compliantly — and every clean lands in the same digital
        record as the inspection that triggered it.
      </p>
      <div class="grid-2" style="margin: var(--space-md) 0;">
        <img
          src="/images/photos/biofouling-ops.png"
          alt="In-water cleaning with capture operations"
          loading="lazy"
          width="600"
          height="400"
          style="border-radius: var(--radius); width: 100%; height: 12rem; object-fit: cover;"
        />
        <img
          src="/images/photos/diver-cleaning-1.jpg"
          alt="Diver niche-area cleaning with capture"
          loading="lazy"
          width="600"
          height="400"
          style="border-radius: var(--radius); width: 100%; height: 12rem; object-fit: cover;"
        />
      </div>
      <div class="btn-row">
        <a class="btn btn--navy" href="/contact">Enquire about cleaning with capture</a>
      </div>
    </div>
  </section>
</SiteLayout>
