<script>
  function initLazyFrames() {
    const roots = document.querySelectorAll("[data-lazy-frame]");
    roots.forEach((root) => {
      const frame = root.querySelector("iframe[data-src]");
      if (!frame || !(frame instanceof HTMLIFrameElement) || !frame.dataset.src) return;

      const io = new IntersectionObserver(
        (entries) => {
          if (entries.some((e) => e.isIntersecting)) {
            frame.setAttribute("src", frame.dataset.src);
            io.disconnect();
          }
        },
        { rootMargin: "120px" },
      );
      io.observe(frame);
    });
  }

  initLazyFrames();
</script>
