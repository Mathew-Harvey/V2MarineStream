---
import SiteLayout from "../../layouts/SiteLayout.astro";
import PageHero from "../../components/PageHero.astro";
import ServiceCta from "../../components/ServiceCta.astro";
import { Image } from "astro:assets";
import bannerImage from "../../assets/photos/rov-product-dark.jpg";
import crawlerImage from "../../assets/photos/iwc-crawler.jpg";
import recoveryImage from "../../assets/photos/rov-recovery.jpg";
import launchImage from "../../assets/photos/rov-launch-gunwale.jpg";
import controllerImage from "../../assets/photos/rov-controller-hands.jpg";
import crawlerUnderwaterImage from "../../assets/photos/crawler-underwater.jpg";
import crawlerSupervisionImage from "../../assets/photos/crawler-supervision.jpg";
import cleaningHudImage from "../../assets/photos/cleaning-progress-hud.jpg";
import puBladeImage from "../../assets/photos/iwc-pu-blade.jpg";
import obdToolImage from "../../assets/photos/iwc-obd-tool.jpg";
import plantOpenImage from "../../assets/photos/filtration-plant-open.jpg";
import powerStandImage from "../../assets/photos/filtration-power-stand.jpg";
import internalsImage from "../../assets/photos/filtration-internals.jpg";
import containerImage from "../../assets/photos/filtration-container.jpg";
import detailImage from "../../assets/photos/filtration-detail.jpg";
import dischargeImage from "../../assets/photos/filtration-discharge.jpg";
---

<SiteLayout
  title="Hardware | Services | MarineStream™"
  description="Three tiers of hull intervention: DeepTrekker ROVs, the CLIIN magnetic crawler, and cleaning with capture through the IWHC filtration plant."
>
  <div class="hw-hero-wrap">
    <PageHero
      eyebrow="Services"
      title="Hardware"
      lead="Three tiers of intervention on a hull — every system proven on Navy and commercial operations before we sell it."
      parent={{ href: "/services", label: "Services" }}
      image={bannerImage}
      imageAlt="Inspection-class ROV photographed against a black background"
    />

    <section class="section hw-pull">
      <div class="container">
        <div class="hw-tiers">
          <a class="hw-tier hw-tier--inspect reveal" href="#inspect">
            <div class="hw-tier__top">
              <span class="hw-tier__label">Tier 01</span>
              <span class="hw-tier__num" aria-hidden="true">01</span>
            </div>
            <h3>Inspect</h3>
            <p>
              Survey and condition assessment with 4K imaging, positioning and live stakeholder
              access.
            </p>
            <ul class="hw-tier__kit">
              <li>DeepTrekker ROVs — Pivot &amp; Revolution</li>
            </ul>
          </a>

          <a class="hw-tier hw-tier--clean reveal" href="#clean">
            <div class="hw-tier__top">
              <span class="hw-tier__label">Tier 02</span>
              <span class="hw-tier__num" aria-hidden="true">02</span>
            </div>
            <h3>Clean</h3>
            <p>
              Robotic in-water hull cleaning, without capture — at berth, anchorage, or at sea with
              the vessel adrift.
            </p>
            <ul class="hw-tier__kit">
              <li>CLIIN magnetic hull crawler</li>
            </ul>
          </a>

          <a class="hw-tier hw-tier--capture reveal" href="#capture">
            <div class="hw-tier__top">
              <span class="hw-tier__label">Tier 03</span>
              <span class="hw-tier__badge">Full compliance</span>
            </div>
            <h3>Clean with capture</h3>
            <p>
              In-water cleaning with full capture plus niche-area tooling — nothing enters the water
              column. Biosecurity-compliant discharge anywhere.
            </p>
            <ul class="hw-tier__kit">
              <li>CLIIN crawler + capture shroud</li>
              <li class="hw-tier__kit-plus">Niche-area tooling for divers</li>
              <li class="hw-tier__kit-plus">IWHC filtration plant</li>
            </ul>
          </a>
        </div>

        <div class="hw-overview reveal">
          <div class="hw-overview__title">
            <span class="eyebrow">Overview</span>
            <h2>We sell what we use</h2>
            <hr class="accent-rule" />
          </div>
          <p>
            Every system on this page earns its keep on our own jobs before it is offered to
            partners. Each tier below builds on the last: the ROVs that inspect a hull also verify
            the clean; the crawler that cleans is the same machine that feeds the capture system.
            One equipment family, three tiers of intervention — backed by deployment support,
            spares and field commissioning.
          </p>
        </div>
      </div>
    </section>
  </div>

  <section id="inspect" class="section section--soft">
    <div class="container">
      <div class="hw-section-head reveal">
        <div class="hw-section-head__row">
          <span class="hw-badge hw-badge--navy">Tier 01</span>
          <span class="eyebrow">Inspection systems</span>
        </div>
        <h2>Inspect — DeepTrekker ROVs</h2>
        <hr class="accent-rule" />
        <p class="hw-lead">
          Survey and intervention-class ROVs with 4K imaging and positioning. The same systems
          document pre- and post-clean condition, with live stakeholder access built into the
          imaging chain. Explore each chassis in 3D below — orbit, zoom and pan to see how the
          systems are put together.
        </p>
      </div>

      <div class="hw-model-grid">
        <article class="hw-model-card reveal" data-lazy-frame>
          <div class="hw-model-card__stage">
            <iframe
              class="hw-model-card__frame"
              title="DeepTrekker Pivot 3D model"
              data-src="/models/viewers/pivot.html"
              loading="lazy"
              allow="fullscreen"
            ></iframe>
            <span class="hw-live-badge">Live 3D</span>
            <noscript>
              <p class="hw-model-card__noscript">
                Enable JavaScript to explore the 3D model, or
                <a href="/models/viewers/pivot.html">open the Pivot viewer</a>.
              </p>
            </noscript>
          </div>
          <div class="hw-model-card__body">
            <span class="hw-model-card__brand">DeepTrekker</span>
            <h3>Pivot</h3>
            <p>
              Inspection-class chassis with 4K camera, LED arrays and sonar. The workhorse for hull
              condition survey. Drag to orbit · scroll to zoom.
            </p>
            <ul class="checklist checklist--compact">
              <li>Survey and intervention ready</li>
              <li>4K imaging and positioning</li>
              <li>Sonar and LED arrays</li>
            </ul>
            <a class="text-link" href="/models/viewers/pivot.html" target="_blank" rel="noopener"
              >Open full-screen viewer</a
            >
          </div>
        </article>

        <article class="hw-model-card reveal" data-lazy-frame>
          <div class="hw-model-card__stage">
            <iframe
              class="hw-model-card__frame"
              title="DeepTrekker Revolution 3D model"
              data-src="/models/viewers/revolution.html"
              loading="lazy"
              allow="fullscreen"
            ></iframe>
            <span class="hw-live-badge">Live 3D</span>
            <noscript>
              <p class="hw-model-card__noscript">
                Enable JavaScript to explore the 3D model, or
                <a href="/models/viewers/revolution.html">open the Revolution viewer</a>.
              </p>
            </noscript>
          </div>
          <div class="hw-model-card__body">
            <span class="hw-model-card__brand">DeepTrekker</span>
            <h3>Revolution</h3>
            <p>
              Heavier intervention chassis with rotating camera head for tooling work and complex
              geometry. Drag to orbit · scroll to zoom.
            </p>
            <ul class="checklist checklist--compact">
              <li>Rotating 260° camera head</li>
              <li>Tooling and manipulator ready</li>
              <li>Station-holding in current</li>
            </ul>
            <a
              class="text-link"
              href="/models/viewers/revolution.html"
              target="_blank"
              rel="noopener">Open full-screen viewer</a
            >
          </div>
        </article>
      </div>

      <div class="hw-caption-trio reveal">
        <figure>
          <Image
            src={launchImage}
            alt="Technician launching an ROV over a vessel gunwale"
            widths={[400, 760]}
            sizes="(min-width: 760px) 22rem, 100vw"
            loading="lazy"
          />
          <figcaption>Launched from wharf or vessel gunwale.</figcaption>
        </figure>
        <figure>
          <Image
            src={controllerImage}
            alt="Operator's hands on ROV controller with live underwater feed"
            widths={[400, 760]}
            sizes="(min-width: 760px) 22rem, 100vw"
            loading="lazy"
          />
          <figcaption>Live feed to every stakeholder who needs it.</figcaption>
        </figure>
        <figure>
          <Image
            src={recoveryImage}
            alt="ROV lifted on slings above harbour water during recovery"
            widths={[400, 760]}
            sizes="(min-width: 760px) 22rem, 100vw"
            loading="lazy"
          />
          <figcaption>Recovery after survey — same systems as the 3D models.</figcaption>
        </figure>
      </div>

      <div class="hw-soft-banner reveal">
        <div class="hw-soft-banner__title">
          <span class="hw-soft-banner__eyebrow">Included</span>
          <strong>Software, out of the box</strong>
        </div>
        <div class="hw-soft-banner__grid">
          <div>
            <strong><a href="/tools/rov-autoconnect">ROV AutoConnect</a></strong>
            <p>The DeepTrekker feed streams straight into the software — no separate capture rig.</p>
          </div>
          <div>
            <strong>Live stakeholder access</strong>
            <p>Owners, class and regulators watch the same survey in real time.</p>
          </div>
          <div>
            <strong>Auto-tagged evidence</strong>
            <p>Every frame lands against its asset and zone in one auditable record.</p>
          </div>
        </div>
        <a class="btn btn--primary" href="/services/software">Software overview</a>
      </div>
    </div>
  </section>

  <section id="clean" class="section section--dark">
    <div class="container">
      <div class="hw-section-head reveal">
        <div class="hw-section-head__row">
          <span class="hw-badge hw-badge--cyan">Tier 02</span>
          <span class="eyebrow">Robotic cleaning</span>
        </div>
        <h2>Clean — the CLIIN magnetic crawler</h2>
        <hr class="accent-rule" />
      </div>

      <div class="hw-clean-grid">
        <div class="reveal">
          <p>
            A remotely operated crawler that works the hull above and below the waterline on
            permanent-magnet tracks — no divers on the plate. A fresh-water cavitation head strips
            fouling without abrasion, preserving modern antifouling coatings.
          </p>
          <p>
            Because the system is robotic and self-adhering, cleaning is not tied to a berth: we
            operate at anchorage and at sea with the vessel adrift.
          </p>
          <div class="hw-stat-tiles">
            <div>
              <div class="hw-stat-tiles__value">250 kg</div>
              <div class="hw-stat-tiles__label">
                Vertical hold — permanent-magnet tracks, no power needed to stay attached
              </div>
            </div>
            <div>
              <div class="hw-stat-tiles__value">200–400 m²/h</div>
              <div class="hw-stat-tiles__label">
                Hull-plate cleaning rate — roughly twice conventional diver operations
              </div>
            </div>
            <div>
              <div class="hw-stat-tiles__value">200 bar</div>
              <div class="hw-stat-tiles__label">
                Fresh-water cavitation head — non-abrasive, coating-safe; brush head optional
              </div>
            </div>
            <div>
              <div class="hw-stat-tiles__value">60 m</div>
              <div class="hw-stat-tiles__label">
                Operational depth — tethered control with cameras, gyro and depth sensing
              </div>
            </div>
          </div>
        </div>

        <div class="hw-clean-media reveal">
          <div class="hw-model-card hw-model-card--dark" data-lazy-frame>
            <div class="hw-model-card__stage">
              <iframe
                class="hw-model-card__frame"
                title="CLIIN hull crawler 3D model"
                data-src="/models/viewers/cliin-crawler.html"
                loading="lazy"
                allow="fullscreen"
              ></iframe>
              <span class="hw-live-badge hw-live-badge--cyan">Live 3D</span>
              <noscript>
                <p class="hw-model-card__noscript">
                  Enable JavaScript to explore the 3D model, or
                  <a href="/models/viewers/cliin-crawler.html">open the CLIIN crawler viewer</a>.
                </p>
              </noscript>
            </div>
            <div class="hw-model-card__body">
              <h3>Explore the CLIIN crawler in 3D</h3>
              <p>
                Orbit the chassis, toggle the foam floats, and see how the tracks and cleaning head
                sit together.
              </p>
              <a
                class="text-link"
                href="/models/viewers/cliin-crawler.html"
                target="_blank"
                rel="noopener">Open full-screen viewer</a
              >
            </div>
          </div>
          <figure class="hw-overlay-fig">
            <Image
              src={crawlerUnderwaterImage}
              alt="Hull cleaning crawler working on a ship's underwater hull"
              widths={[480, 900]}
              sizes="(min-width: 900px) 28rem, 100vw"
              loading="lazy"
            />
            <figcaption>
              The crawler working the underwater hull on permanent-magnet tracks.
            </figcaption>
          </figure>
        </div>
      </div>

      <div class="hw-caption-duo reveal">
        <figure>
          <Image
            src={crawlerSupervisionImage}
            alt="Operator supervising a hull crawler working at a ship's waterline"
            widths={[640, 1100]}
            sizes="(min-width: 900px) 32rem, 100vw"
            loading="lazy"
          />
          <figcaption>One operator supervises from the surface — no divers on the plate.</figcaption>
        </figure>
        <figure>
          <Image
            src={cleaningHudImage}
            alt="Live cleaning telemetry showing the boundary between fouled and cleaned hull"
            widths={[640, 1100]}
            sizes="(min-width: 900px) 32rem, 100vw"
            loading="lazy"
          />
          <figcaption>Mid-clean telemetry: the fouled-to-clean boundary, recorded live.</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section id="capture" class="section">
    <div class="container">
      <div class="hw-section-head reveal">
        <div class="hw-section-head__row">
          <span class="hw-badge hw-badge--orange">Tier 03</span>
          <span class="eyebrow">Cleaning with capture</span>
        </div>
        <h2>Clean with capture — the complete system</h2>
        <hr class="accent-rule" />
        <p class="hw-lead">
          Tier 2's crawler, plus everything needed so nothing enters the water column. Three
          elements, one uplift line, one filtration plant — meeting biosecurity discharge standards
          anywhere in the world.
        </p>
      </div>

      <div class="hw-capture-parts">
        <article class="hw-capture-part reveal">
          <Image
            src={crawlerImage}
            alt="Magnetic hull crawler with cavitation head and dual capture ports"
            widths={[480, 900]}
            sizes="(min-width: 900px) 22rem, 100vw"
            loading="lazy"
          />
          <div class="hw-capture-part__body">
            <span class="hw-capture-part__step">1 · Capture shroud</span>
            <h3>What makes our crawler different</h3>
            <p>
              Off the shelf, the crawler releases what it removes. Our custom-engineered shroud
              encloses the cavitation head with dual debris-exhaust ports, holding negative pressure
              at the hull and drawing ~1,200 L/min of effluent straight into the uplift line.
            </p>
          </div>
        </article>

        <article class="hw-capture-part reveal">
          <div class="hw-capture-part__split">
            <Image
              src={puBladeImage}
              alt="Polyurethane-bladed diver hand tool"
              widths={[320, 480]}
              sizes="12rem"
              loading="lazy"
            />
            <Image
              src={obdToolImage}
              alt="Valve-isolated rotary capture cup for overboard discharges"
              widths={[320, 480]}
              sizes="12rem"
              loading="lazy"
            />
          </div>
          <div class="hw-capture-part__body">
            <span class="hw-capture-part__step">2 · Niche-area tooling</span>
            <h3>Where the crawler can't reach</h3>
            <p>
              Propellers, rudders, sea chests, bilge keels and thrusters are cleaned by divers with
              suction-through-head blades and capture cups. Every head — robotic, handheld or
              penetration — returns its effluent through the same uplift line.
            </p>
          </div>
        </article>

        <article class="hw-capture-part reveal">
          <Image
            src={plantOpenImage}
            alt="IWHC filtration plant in an open 20 ft ISO container"
            widths={[480, 900]}
            sizes="(min-width: 900px) 22rem, 100vw"
            loading="lazy"
          />
          <div class="hw-capture-part__body">
            <span class="hw-capture-part__step">3 · IWHC filtration plant</span>
            <h3>Filter, disinfect, discharge</h3>
            <p>
              A self-contained, ISO-deployable plant captures, filters and disinfects the full
              stream. Every drop passes all four stages — there is no bypass — and solids are bagged
              for compliant disposal.
            </p>
          </div>
        </article>
      </div>

      <div class="hw-proof reveal">
        <div class="hw-proof__copy">
          <span class="hw-proof__eyebrow">Proven in service</span>
          <p>
            Australia's first robotic in-water hull clean with full capture — on a Royal Australian
            Navy vessel.
          </p>
        </div>
        <div class="hw-proof__stats">
          <div>
            <div class="hw-proof__value">FR 0</div>
            <div class="hw-proof__label">Post-clean rating, all inspected areas</div>
          </div>
          <div>
            <div class="hw-proof__value">~2×</div>
            <div class="hw-proof__label">Diver cleaning rate on hull plate</div>
          </div>
          <div>
            <div class="hw-proof__value">≤3.8 ppb</div>
            <div class="hw-proof__label">Dissolved copper in discharge</div>
          </div>
        </div>
      </div>

      <div class="hw-filter-head reveal">
        <div>
          <span class="eyebrow">The IWHC filtration plant</span>
          <h3>Four stages, no bypass</h3>
        </div>
        <div class="hw-filter-head__stats">
          <div>
            <strong>1,200 L/min</strong>
            <span>Max throughput</span>
          </div>
          <div>
            <strong>≤10 μm → 5 μm</strong>
            <span>Filtration, then UV</span>
          </div>
          <div>
            <strong>20 ft HC ISO</strong>
            <span>One containerised unit</span>
          </div>
        </div>
      </div>

      <ol class="hw-stages reveal">
        <li>
          <span class="hw-stages__num">01</span>
          <strong>Bow screen</strong>
          <p>Coarse solids separated to a catch bag; filtrate drains to the bund.</p>
        </li>
        <li class="hw-stages__highlight">
          <span class="hw-stages__tag">Self-cleaning · never blinds</span>
          <span class="hw-stages__num">02</span>
          <strong>25 μm micro-screen</strong>
          <p>
            Non-pressurised and gravity-fed, with twin spraybars sweeping the screen continuously —
            it handles the fibrous, shell-laden waste that defeats conventional filters.
          </p>
        </li>
        <li>
          <span class="hw-stages__num">03</span>
          <strong>Bag filter</strong>
          <p>Eight parallel housings polish the stream down to 5 μm.</p>
        </li>
        <li>
          <span class="hw-stages__num">04</span>
          <strong>UV disinfection</strong>
          <p>Quartz-sleeved UV array inactivates organisms before discharge.</p>
        </li>
      </ol>

      <div class="hw-chips-row reveal">
        <div class="hw-chips">
          <span>≥95% capture within 300 mm of tool</span>
          <span>Intersleek® approved, non-abrasive</span>
          <span>IMO MEPC.378(80)</span>
          <span>ANZECC verified</span>
        </div>
      </div>

      <div class="hw-mosaic-head reveal">
        <div>
          <span class="eyebrow">The plant in the field</span>
          <h3>Filtration, deployed</h3>
        </div>
        <p>
          The plant, the treatment train, and the capture line in operation — from wharf to
          discharge.
        </p>
      </div>

      <div class="hw-mosaic reveal">
        <figure class="hw-mosaic__hero">
          <Image
            src={internalsImage}
            alt="Stainless treatment train and control panel inside the container"
            widths={[768, 1280]}
            sizes="(min-width: 900px) 40rem, 100vw"
            loading="lazy"
          />
          <figcaption>Stainless treatment train and control panel inside the container.</figcaption>
        </figure>
        <figure>
          <Image
            src={containerImage}
            alt="Franmarine-branded 20 ft ISO container housing the filtration plant"
            widths={[480, 900]}
            sizes="(min-width: 900px) 28rem, 100vw"
            loading="lazy"
          />
          <figcaption>Deployed worldwide as a single ISO unit.</figcaption>
        </figure>
        <figure>
          <Image
            src={powerStandImage}
            alt="Motorised hose reel on the mobile power stand"
            widths={[480, 900]}
            sizes="(min-width: 900px) 28rem, 100vw"
            loading="lazy"
          />
          <figcaption>Hose management &amp; mobile power stand.</figcaption>
        </figure>
        <figure>
          <Image
            src={detailImage}
            alt="Filtration plant detail on the wharf with stainless vessels and pumps"
            widths={[640, 1100]}
            sizes="(min-width: 900px) 32rem, 100vw"
            loading="lazy"
          />
          <figcaption>Running from the wharf — stainless vessels and pumps on station.</figcaption>
        </figure>
        <figure>
          <Image
            src={dischargeImage}
            alt="Treated water discharge returning to the harbour"
            widths={[640, 1100]}
            sizes="(min-width: 900px) 32rem, 100vw"
            loading="lazy"
          />
          <figcaption>Treated water returning to the harbour — ≤3.8 ppb dissolved copper.</figcaption>
        </figure>
      </div>

      <details class="hw-detail reveal">
        <summary>Engineering detail — stages &amp; OEM equipment</summary>
        <div class="hw-detail__grid">
          <article>
            <span>Capture &amp; uplift · Hydra-Tech · HYDAC</span>
            <p>
              <strong>Uplift pump</strong> Hydra-Tech S4SCR 4″ submersible<br />
              <strong>Power unit</strong> HYDAC diesel HPU<br />
              <strong>Hose mgmt</strong> Motorised reel stand · 100 mm
            </p>
          </article>
          <article>
            <span>Stage 01 · Bow screen</span>
            <p>
              <strong>Function</strong> First-pass solids capture<br />
              <strong>Solids</strong> Directed to hopper &amp; bulker bag<br />
              <strong>Water mgmt</strong> Float-controlled bund return
            </p>
          </article>
          <article>
            <span>Stage 02 · 25 micron screen</span>
            <p>
              <strong>Type</strong> Self-cleaning flat micro-screen, 316 SS<br />
              <strong>Process</strong> Non-pressurised, gravity-fed<br />
              <strong>Cleaning</strong> Twin-spraybar continuous sweep<br />
              <strong>Capacity</strong> Up to 400 m³/h per unit, modular banks
            </p>
          </article>
          <article>
            <span>Stage 03 · Bag filter · Feature-Tec</span>
            <p>
              <strong>Config</strong> 8 × bag filter housings<br />
              <strong>Rating</strong> Polishing to 5 μm<br />
              <strong>Connections</strong> DN150 in / out · 10 bar design
            </p>
          </article>
          <article>
            <span>Stage 04 · UV · Evoqua</span>
            <p>
              <strong>Model</strong> Spectra UV VX-4340-B<br />
              <strong>Lamps</strong> 4 × quartz-sleeved UV<br />
              <strong>Max pressure</strong> 145 psi (10 bar)
            </p>
          </article>
          <article>
            <span>Ancillaries · Atlas Copco · ABB · Grundfos</span>
            <p>
              <strong>Compressor</strong> Atlas Copco SO G4FF · 10 bar<br />
              <strong>Drive</strong> ABB ACS580 VSD<br />
              <strong>FW booster</strong> Grundfos CM 5-4
            </p>
          </article>
        </div>
      </details>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <div class="hw-overview reveal">
        <div class="hw-overview__title">
          <span class="eyebrow">Supply and support</span>
          <h2>Commissioned in the field, not shipped in a crate</h2>
          <hr class="accent-rule" />
        </div>
        <p>
          Hardware comes with deployment support, spares, and commissioning on your site. Crews can
          be trained on the same equipment through our
          <a href="/services/training">training programs</a>, and every system integrates with the
          <a href="/services/software">MarineStream software</a> out of the box.
        </p>
      </div>
    </div>
  </section>

  <ServiceCta
    title="Spec the right system"
