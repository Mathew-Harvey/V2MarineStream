---
import SiteLayout from "../../layouts/SiteLayout.astro";
import PageHero from "../../components/PageHero.astro";
import ServiceGrid from "../../components/ServiceGrid.astro";
import bannerImage from "../../assets/photos/offshore-mooring-ops.jpg";
---

<SiteLayout
  title="Services | MarineStream™"
  description="Inspection, cleaning with capture, platform, hardware, software, training, and IMS expertise."
>
  <PageHero
    eyebrow="What we do"
    title="Services"
    lead="Capability for partners who deliver IMO-compliant biofouling inspections and cleans."
    image={bannerImage}
    imageAlt="Offshore support vessel during mooring operations"
  />

  <section class="section">
    <div class="container narrow">
      <ServiceGrid />
    </div>
  </section>
</SiteLayout>
