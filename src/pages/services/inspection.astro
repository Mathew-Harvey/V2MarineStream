---
import SiteLayout from "../../layouts/SiteLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { Image } from "astro:assets";
import bannerImage from "../../assets/photos/rov-inspection-lights.jpg";
import bodyImage from "../../assets/photos/rov-controller-hands.jpg";
---

<SiteLayout
  title="Inspection | MarineStream™"
  description="High-definition ROV and diver surveys with live multi-stakeholder access."
>
  <PageHero
    eyebrow="Services"
    title="Inspection"
    lead="Hull, propeller, and niche-area surveys with fouling ratings captured at the point of survey."
    parent={{ href: "/services", label: "Services" }}
    image={bannerImage}
    imageAlt="Inspection ROV with lights on approaching a fouled mooring chain"
  />

  <section class="section">
    <div class="container narrow">
      <Image
        class="service-photo"
        src={bodyImage}
        alt="Operator's hands on an ROV controller showing a live underwater feed"
        widths={[480, 900]}
        sizes="(min-width: 800px) 42rem, 100vw"
        loading="lazy"
      />
      <ul>
        <li>4K imaging and HD recording</li>
        <li>Positioning and sonar for repeatable coverage</li>
        <li>Live multi-stakeholder access to footage</li>
        <li>Direct MarineStream™ platform integration</li>
      </ul>
      <p>
        Partners use these workflows to deliver consistent, auditable surveys without reinventing
        reporting for every client and jurisdiction.
      </p>
      <div class="btn-row">
        <a class="btn btn--navy" href="/contact">Enquire about inspection</a>
      </div>
    </div>
  </section>
</SiteLayout>
