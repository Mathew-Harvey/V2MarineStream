---
import SiteLayout from "../../layouts/SiteLayout.astro";
import PageHero from "../../components/PageHero.astro";
import bannerImage from "../../assets/photos/dive-control-room.jpg";
---

<SiteLayout
  title="Platform | MarineStream™"
  description="Cloud-native biofouling and underwater asset management: field capture, parallel workflows, automated reporting."
>
  <PageHero
    eyebrow="Services"
    title="Platform"
    lead="Field capture once. Parallel review. Audit-ready reports, automatically."
    parent={{ href: "/services", label: "Services" }}
    image={bannerImage}
    imageAlt="Dive supervision control room with live monitoring screens"
  />

  <section class="section">
    <div class="container narrow">
      <img
        class="service-photo"
        src="/images/photos/platform-mock.png"
        alt="MarineStream platform dashboard"
        loading="lazy"
        width="900"
        height="560"
      />
      <div class="stat-row">
        <div>
          <div class="stat__value">80%</div>
          <div class="stat__label">Less reporting time</div>
        </div>
        <div>
          <div class="stat__value">120+</div>
          <div class="stat__label">Vessels managed</div>
        </div>
        <div>
          <div class="stat__value">100%</div>
          <div class="stat__label">Compliant to date</div>
        </div>
        <div>
          <div class="stat__value">99.9%</div>
          <div class="stat__label">Uptime</div>
        </div>
      </div>

      <h2>What it covers</h2>
      <div class="grid-2" style="margin-top: var(--space-md);">
        <div class="feature-block">
          <h3>Work capture</h3>
          <p>Mobile job records with photo, video, notes, and ROV/CCTV ingest.</p>
        </div>
        <div class="feature-block">
          <h3>Multi-party workflows</h3>
          <p>Parallel approvals, no sequential email chains.</p>
        </div>
        <div class="feature-block">
          <h3>Compliance reporting</h3>
          <p>BFMPs, logs, and reports to IMO, biosecurity, and defence frameworks.</p>
        </div>
        <div class="feature-block">
          <h3>Audit trail</h3>
          <p>Blockchain-verified actions. Digital twin per vessel.</p>
        </div>
      </div>

      <div class="btn-row">
        <a class="btn btn--navy" href="/contact">Request a briefing</a>
      </div>
    </div>
  </section>
</SiteLayout>
