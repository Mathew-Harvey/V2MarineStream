---
import SiteLayout from "../../layouts/SiteLayout.astro";
import PageHero from "../../components/PageHero.astro";
import ServiceCta from "../../components/ServiceCta.astro";
import { Image } from "astro:assets";
import bannerImage from "../../assets/photos/dive-control-room.jpg";
import feedsImage from "../../assets/photos/control-room-live-feeds.jpg";
import hudImage from "../../assets/photos/cleaning-progress-hud.jpg";
---

<SiteLayout
  title="Platform | MarineStream™"
  description="Cloud-native biofouling and underwater asset management: field capture, parallel workflows, automated reporting."
>
  <PageHero
    eyebrow="Services"
    title="Platform"
    lead="Field capture once. Parallel review. Audit-ready reports, automatically."
    parent={{ href: "/services", label: "Services" }}
    image={bannerImage}
    imageAlt="Dive supervision control room with live monitoring screens"
  />

  <section class="section">
    <div class="container narrow">
      <span class="eyebrow">Overview</span>
      <h2>One record from survey to sign-off</h2>
      <hr class="accent-rule" />
      <p>
        Biofouling compliance fails in the paperwork more often than in the water. The MarineStream
        platform closes that gap: field teams capture evidence once, stakeholders review in
        parallel rather than by email chain, and the compliance report generates itself from the
        record everyone already saw.
      </p>
      <div class="stat-row">
        <div>
          <div class="stat__value">80%</div>
          <div class="stat__label">Less reporting time</div>
        </div>
        <div>
          <div class="stat__value">120+</div>
          <div class="stat__label">Vessels managed</div>
        </div>
        <div>
          <div class="stat__value">100%</div>
          <div class="stat__label">Compliant to date</div>
        </div>
        <div>
          <div class="stat__value">99.9%</div>
          <div class="stat__label">Uptime</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container narrow">
      <span class="eyebrow">What it covers</span>
      <h2>Built around the job, not the form</h2>
      <hr class="accent-rule" />
      <div class="grid-2" style="margin-top: var(--space-md);">
        <div class="feature-block reveal">
          <h3>Work capture</h3>
          <p>Mobile job records with photo, video, notes, and ROV/CCTV ingest.</p>
        </div>
        <div class="feature-block reveal">
          <h3>Multi-party workflows</h3>
          <p>Parallel approvals, no sequential email chains.</p>
        </div>
        <div class="feature-block reveal">
          <h3>Compliance reporting</h3>
          <p>BFMPs, logs, and reports to IMO, biosecurity, and defence frameworks.</p>
        </div>
        <div class="feature-block reveal">
          <h3>Audit trail</h3>
          <p>Blockchain-verified actions. Digital twin per vessel.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2">
        <figure class="figure reveal" style="margin: 0;">
          <Image
            src={feedsImage}
            alt="Operator monitoring live underwater feeds in a control room"
            widths={[480, 900]}
            sizes="(min-width: 800px) 32rem, 100vw"
            loading="lazy"
          />
          <figcaption>Live feeds from the water reviewed as the work happens.</figcaption>
        </figure>
        <figure class="figure reveal" style="margin: 0;">
          <Image
            src={hudImage}
            alt="Cleaning telemetry captured directly into the platform record"
            widths={[480, 900]}
            sizes="(min-width: 800px) 32rem, 100vw"
            loading="lazy"
          />
          <figcaption>Telemetry and evidence attach to the job record automatically.</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <span class="eyebrow">Who works in it</span>
      <h2>Everyone sees the same job</h2>
      <hr class="accent-rule" />
      <ol class="steps steps--three">
        <li>
          <strong>Field teams</strong>
          <p>Capture evidence and ratings on the job. No paperwork to reconstruct afterwards.</p>
        </li>
        <li>
          <strong>Vessel operators</strong>
          <p>Track fleet fouling state, approve work, and hold one auditable history per vessel.</p>
        </li>
        <li>
          <strong>Reviewers and regulators</strong>
          <p>See live or recorded evidence and sign off in parallel with other stakeholders.</p>
        </li>
      </ol>
      <div class="tool-callout reveal">
        <div>
          <strong>Need a biofouling management plan?</strong>
          <p>The BFMP Generator drafts an IMO-aligned plan from your vessel details, free to use.</p>
        </div>
        <a class="btn btn--navy" href="/interactive-tools/bfmpGen.html">Open the BFMP Generator</a>
      </div>
    </div>
  </section>

  <ServiceCta
    title="See the platform on a real job"
    lead="A short briefing with your own vessel or fleet as the example beats a feature list. Tell us what you operate and we will set it up."
    primaryHref="/contact"
    primaryLabel="Request a briefing"
    secondaryHref="/services/software"
    secondaryLabel="Subscription options"
  />
</SiteLayout>
