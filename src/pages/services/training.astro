---
import SiteLayout from "../../layouts/SiteLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { Image } from "astro:assets";
import bannerImage from "../../assets/photos/training-demo.jpg";
import bodyImage from "../../assets/photos/crew-crawler-workshop.jpg";
---

<SiteLayout
  title="Training | Services | MarineStream™"
  description="ROV, biofouling management, and platform training for operators and supervisors."
>
  <PageHero
    eyebrow="Services"
    title="Training"
    lead="Programs delivered by people who run the operations, not classroom theory alone."
    parent={{ href: "/services", label: "Services" }}
    image={bannerImage}
    imageAlt="Group training demonstration at a shipyard"
  />

  <section class="section">
    <div class="container narrow">
      <Image
        class="service-photo"
        src={bodyImage}
        alt="Crew inspecting a hull crawler in a vessel workshop"
        widths={[480, 900]}
        sizes="(min-width: 800px) 42rem, 100vw"
        loading="lazy"
      />
      <ul>
        <li>ROV pilot and supervisor training</li>
        <li>Biofouling management and IMO-aligned inspection practice</li>
        <li>Platform and reporting workshops for field and office teams</li>
        <li>On-site, remote, and blended delivery</li>
      </ul>
      <p>
        Training packages can be scoped to your fleet, jurisdiction, and equipment. Contact us for
        a program outline.
      </p>
      <div class="btn-row">
        <a class="btn btn--navy" href="/contact">Enquire about training</a>
        <a class="btn btn--primary" href="/services/professional-services">Professional services</a>
      </div>
    </div>
  </section>
</SiteLayout>
